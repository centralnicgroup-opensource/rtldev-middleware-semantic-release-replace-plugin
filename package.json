{
  "name": "semantic-release-replace-plugin",
  "version": "1.2.7",
  "description": "Semantic Release Replace Plugin v2",
  "keywords": [
    "semantic-release",
    "node",
    "replace"
  ],
  "repository": "github:centralnicgroup-opensource/rtldev-middleware-semantic-release-replace-plugin.git",
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "files": [
    "dist/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "all": "pnpm run build && pnpm run docs",
    "build": "tsc",
    "docs": "rm -rf docs && typedoc src/index.ts",
    "lint": "prettier --write . --ignore-path .prettierignore && eslint",
    "format": "eslint --fix",
    "test": "tsc --noEmit && vitest --coverage",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage --run",
    "ci": "pnpm run build && pnpm run test && pnpm run lint",
    "prepublishOnly": "pnpm run build && pnpm run test",
    "release": "semantic-release"
  },
  "dependencies": {
    "replace-in-file": "^8.4.0",
    "semantic-release": "^25.0.5"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "fs-extra": "^11.3.5",
    "prettier": "^3.8.4",
    "@team-internet/semantic-release-plugins": "^1.0.6",
    "tmp": "^0.2.7",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "^24.10.0"
  },
  "publishConfig": {
    "access": "public"
  }
}